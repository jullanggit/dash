#!/usr/bin/env bash
set -e
if [[ ! -d "/etc/nixos/home/data/Code/rust/dashboard" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/etc/nixos/home/data/Code/rust/dashboard")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/etc/nixos/home/data/Code/rust/dashboard" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/etc/nixos/home/data/Code/rust/dashboard/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/etc/nixos/home/data/Code/rust/dashboard/.envrc" "/etc/nixos/home/data/Code/rust/dashboard/.direnv"/*.rc
